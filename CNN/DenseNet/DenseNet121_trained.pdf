            "\u001b[1m540/540\u001b[0m \u001b[32m━━━━━━━━━━━━━━━━━━━━\u001b[0m\u001b[37m\u001b[0m \u001b[1m45s\u001b[0m 84ms/step - accuracy: 0.9002 - loss: 0.2592 - val_accuracy: 0.8465 - val_loss: 0.3921\n"
